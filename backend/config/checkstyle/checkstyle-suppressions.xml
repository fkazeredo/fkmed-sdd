<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<!--
  Deliberate, documented exceptions — never a way around a real violation:
  - The Spring Boot application class only carries main(); it is not a utility class.
  - Test conventions: BDD method names with underscores and ArchUnit @ArchTest rule fields
    (camelCase static finals) are the test-code norm (docs/architecture/testing.md).
-->
<suppressions>
  <suppress checks="HideUtilityClassConstructor" files="FkmedApplication\.java"/>
  <suppress checks="MethodName|ConstantName|HideUtilityClassConstructor"
            files="[\\/]src[\\/]test[\\/]"/>
</suppressions>
