# FKMed — development environment defaults (safe to commit; SECURITY.md enumerates them).
# Copy to .env and adjust. NEVER commit a real .env / .env.prod (gitleaks + .gitignore).

# --- Database (dev-only default password; refused in prod by ProdReadinessValidator) ---
POSTGRES_DB=fkmed
POSTGRES_USER=fkmed
POSTGRES_PASSWORD=fkmed

# --- Application ---
SPRING_PROFILES_ACTIVE=dev
APP_ISSUER=http://localhost:8080
APP_ALLOWED_ORIGINS=http://localhost:4200
APP_OIDC_REDIRECT_URIS=http://localhost:4200/
APP_OIDC_POST_LOGOUT_REDIRECT_URIS=http://localhost:4200/
# Production requires a persisted PKCS#8 RSA key (DECISIONS-BASELINE §0020); dev generates
# an ephemeral one when empty.
OIDC_JWK_PRIVATE_KEY=
# HMAC secret for the first-access registration token (DL-0001); prod must set it
# (ProdReadinessValidator). Blank ⇒ ephemeral dev secret.
REGISTRATION_TOKEN_SECRET=

# --- E-mail (dev SMTP catcher: Mailpit — ADR-0004; prod sets a real SMTP host) ---
SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025
APP_WEB_BASE_URL=http://localhost:4200
MAILPIT_HTTP_PORT=8025

# --- Observability (dev-only default; set real values in .env.prod) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Production images (compose.prod.yaml) ---
BACKEND_IMAGE=ghcr.io/fkazeredo/fkmed-backend:latest
FRONTEND_IMAGE=ghcr.io/fkazeredo/fkmed-frontend:latest

# --- Host ports (change when another stack already uses the defaults) ---
POSTGRES_PORT=5432
APP_PORT=8080

# --- Uploaded-file storage (SPEC-0019 / ADR-0023) ---
# dev defaults to filesystem; use "postgres" to retain binary database storage.
FKMED_STORAGE_BACKEND=filesystem
# Container path. Running the backend directly on Windows may use C:/fkmed/uploads.
FKMED_STORAGE_FILESYSTEM_ROOT=/fkmed/uploads

# Production uses private S3. Prefer an IAM role; static credentials are optional and must never
# be committed. SSE-S3 is automatic when no KMS key is configured.
FKMED_STORAGE_S3_BUCKET=
FKMED_STORAGE_S3_PREFIX=fkmed
FKMED_STORAGE_S3_KMS_KEY_ID=
FKMED_STORAGE_S3_ENDPOINT=
FKMED_STORAGE_S3_PATH_STYLE=false
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
