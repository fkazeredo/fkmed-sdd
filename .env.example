# FKMed — development environment defaults (safe to commit; SECURITY.md enumerates them).
# Copy to .env and adjust. NEVER commit a real .env / .env.prod (gitleaks + .gitignore).

# --- Database (dev-only default password; refused in prod by ProdReadinessValidator) ---
POSTGRES_DB=fkmed
POSTGRES_USER=fkmed
POSTGRES_PASSWORD=fkmed

# --- Application ---
SPRING_PROFILES_ACTIVE=dev
APP_ISSUER=http://localhost:8080
APP_ALLOWED_ORIGINS=http://localhost:4200
APP_OIDC_REDIRECT_URIS=http://localhost:4200/
APP_OIDC_POST_LOGOUT_REDIRECT_URIS=http://localhost:4200/
# Production requires a persisted PKCS#8 RSA key (DECISIONS-BASELINE §0020); dev generates
# an ephemeral one when empty.
OIDC_JWK_PRIVATE_KEY=

# --- Observability (dev-only default; set real values in .env.prod) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Production images (compose.prod.yaml) ---
BACKEND_IMAGE=ghcr.io/fkazeredo/fkmed-backend:latest
FRONTEND_IMAGE=ghcr.io/fkazeredo/fkmed-frontend:latest

# --- Host ports (change when another stack already uses the defaults) ---
POSTGRES_PORT=5432
APP_PORT=8080
