              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "OK"
          }
        }
      }
    },
    "/api/auth/recovery/request" : {
      "post" : {
        "tags" : [ "recovery-controller" ],
        "operationId" : "request",
        "requestBody" : {
          "content" : {
