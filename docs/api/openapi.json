          "200" : {
            "description" : "OK",
            "content" : {
              "*/*" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/AccessibleBeneficiary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/content/home" : {
