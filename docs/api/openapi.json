                }
              }
            }
          }
        }
      }
    },
    "/api/context/beneficiaries/{beneficiaryId}" : {
      "get" : {
        "tags" : [ "context-controller" ],
        "operationId" : "beneficiary",
        "parameters" : [ {
          "name" : "beneficiaryId",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "string",
            "format" : "uuid"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "*/*" : {
                "schema" : {
                  "$ref" : "#/components/schemas/BeneficiarySummary"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/accessible-beneficiaries" : {
      "get" : {
        "tags" : [ "context-controller" ],
