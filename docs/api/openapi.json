          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "string",
            "format" : "uuid"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/pdf" : {
                "schema" : {
                  "type" : "string",
                  "format" : "byte"
                }
              }
            }
          }
        }
      }
    }
  },
  "components" : {
    "schemas" : {
      "ChangePasswordRequest" : {
        "type" : "object",
        "properties" : {
          "currentPassword" : {
            "type" : "string",
            "minLength" : 1
          },
          "newPassword" : {
            "type" : "string",
            "minLength" : 1
          }
        },
        "required" : [ "currentPassword", "newPassword" ]
      },
      "ResendVerificationRequest" : {
        "type" : "object",
        "properties" : {
          "email" : {
            "type" : "string",
            "format" : "email",
            "minLength" : 1
          }
        },
        "required" : [ "email" ]
      },
      "ConfirmVerificationRequest" : {
        "type" : "object",
        "properties" : {
          "token" : {
            "type" : "string",
            "minLength" : 1
          }
        },
        "required" : [ "token" ]
      },
      "PasswordResetRequest" : {
        "type" : "object",
        "properties" : {
          "token" : {
            "type" : "string",
            "minLength" : 1
          },
          "newPassword" : {
            "type" : "string",
            "minLength" : 1
          }
        },
        "required" : [ "newPassword", "token" ]
      },
      "PasswordRecoveryRequest" : {
        "type" : "object",
        "properties" : {
          "email" : {
            "type" : "string",
            "format" : "email",
            "minLength" : 1
          }
        },
        "required" : [ "email" ]
      },
      "VerifyFirstAccessRequest" : {
        "type" : "object",
        "properties" : {
          "cpf" : {
            "type" : "string",
            "minLength" : 1,
            "pattern" : "\\d{11}"
          },
          "cardNumber" : {
            "type" : "string",
            "minLength" : 1,
            "pattern" : "\\d{9}"
          },
          "birthDate" : {
            "type" : "string",
            "format" : "date"
          }
        },
        "required" : [ "birthDate", "cardNumber", "cpf" ]
      },
      "VerifyFirstAccessResponse" : {
        "type" : "object",
        "properties" : {
          "registrationToken" : {
            "type" : "string"
          }
        }
      },
      "CompleteFirstAccessRequest" : {
        "type" : "object",
        "properties" : {
          "registrationToken" : {
            "type" : "string",
            "minLength" : 1
          },
          "email" : {
            "type" : "string",
            "format" : "email",
            "maxLength" : 160,
            "minLength" : 0
          },
          "password" : {
            "type" : "string",
            "minLength" : 1
          },
          "acceptedTerms" : {
            "type" : "boolean"
          },
          "acceptedPrivacy" : {
            "type" : "boolean"
          }
        },
        "required" : [ "email", "password", "registrationToken" ]
      },
      "SystemVersionResponse" : {
        "type" : "object",
        "properties" : {
          "version" : {
            "type" : "string"
          },
          "commit" : {
            "type" : "string"
          }
        }
      },
      "SystemHealthResponse" : {
        "type" : "object",
        "properties" : {
          "status" : {
            "type" : "string"
          },
          "database" : {
            "type" : "string"
          }
        }
      },
      "MemberSummary" : {
        "type" : "object",
        "properties" : {
          "fullName" : {
            "type" : "string"
          },
          "role" : {
            "type" : "string",
            "enum" : [ "TITULAR", "DEPENDENT" ]
          },
          "cardNumber" : {
            "type" : "string"
          }
        }
      },
      "MyPlanResponse" : {
        "type" : "object",
        "properties" : {
          "plan" : {
            "$ref" : "#/components/schemas/PlanSummary"
          },
          "members" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/MemberSummary"
            }
          }
        }
      },
      "PlanSummary" : {
        "type" : "object",
        "properties" : {
          "name" : {
            "type" : "string"
          },
          "ansRegistration" : {
            "type" : "string"
          },
          "coverage" : {
            "type" : "string"
          },
          "copay" : {
            "type" : "boolean"
          },
          "reimbursement" : {
            "type" : "boolean"
          },
          "additives" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          }
        }
      },
      "BeneficiarySummary" : {
        "type" : "object",
        "properties" : {
          "beneficiaryId" : {
            "type" : "string",
            "format" : "uuid"
          },
          "firstName" : {
            "type" : "string"
          },
          "fullName" : {
            "type" : "string"
          },
          "role" : {
            "type" : "string",
            "enum" : [ "TITULAR", "DEPENDENT" ]
          },
          "planName" : {
            "type" : "string"
          },
          "cardNumber" : {
            "type" : "string"
          },
          "avatarUrl" : {
            "type" : "string"
          }
        }
      },
      "AccessibleBeneficiary" : {
        "type" : "object",
        "properties" : {
          "beneficiaryId" : {
            "type" : "string",
            "format" : "uuid"
          },
          "firstName" : {
            "type" : "string"
          },
          "role" : {
            "type" : "string",
            "enum" : [ "TITULAR", "DEPENDENT" ]
          }
        }
      },
      "BannerView" : {
        "type" : "object",
        "properties" : {
          "title" : {
            "type" : "string"
          },
          "text" : {
            "type" : "string"
          },
          "buttonLabel" : {
            "type" : "string"
          },
          "destination" : {
            "type" : "string"
          },
          "imageUrl" : {
            "type" : "string"
          },
          "order" : {
            "type" : "integer",
            "format" : "int32"
          }
        }
      },
      "HomeContentResponse" : {
        "type" : "object",
        "properties" : {
          "banners" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/BannerView"
            }
          },
          "notices" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/NoticeView"
            }
          }
        }
      },
      "NoticeView" : {
        "type" : "object",
        "properties" : {
          "title" : {
            "type" : "string"
          },
          "severity" : {
            "type" : "string",
            "enum" : [ "INFORMATIVE", "ALERT" ]
          },
          "body" : {
            "type" : "string"
          },
          "order" : {
            "type" : "integer",
            "format" : "int32"
          }
        }
      },
      "CardResponse" : {
        "type" : "object",
        "properties" : {
          "fullName" : {
            "type" : "string"
          },
          "cardNumber" : {
            "type" : "string"
          },
          "cns" : {
            "type" : "string"
          },
          "ansRegistration" : {
            "type" : "string"
          },
          "coverage" : {
            "type" : "string"
          },
          "planName" : {
            "type" : "string"
          },
          "planCategory" : {
            "type" : "string"
          },
          "additives" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          }
        }
      }
    }
  }
}
